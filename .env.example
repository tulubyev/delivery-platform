# ── Database (Beget PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/delivery_db?schema=public"

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Upstash для Replit:
# REDIS_URL="rediss://default:TOKEN@REGION.upstash.io:6379"

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-random-256-bit-secret"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="another-random-secret"

# ── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173"

# ── Notifications ────────────────────────────────────────────────────────────
SMS_API_KEY=""
SMS_SENDER=""
FCM_SERVER_KEY=""
